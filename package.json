{
  "name": "archive-at-home",
  "private": true,
  "version": "1.0.0",
  "description": "Archive-at-Home site (static main site + VitePress docs)",
  "workspaces": [
    "apps/docs"
  ],
  "scripts": {
    "dev": "npm run build && node scripts/serve-site.mjs",
    "dev:serve": "node scripts/serve-site.mjs",
    "docs:dev": "npm run dev -w @archive-at-home/docs",
    "docs:build": "npm run build -w @archive-at-home/docs",
    "docs:preview": "npm run preview -w @archive-at-home/docs",
    "build": "node scripts/build-root.mjs",
    "build:gh": "node scripts/build-gh.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
