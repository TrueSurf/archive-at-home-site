---
/** API 端点文档块：方法徽章 + 路径 + 摘要，内容走默认插槽 */
interface Props {
  method: 'GET' | 'POST' | 'PUT' | 'DELETE';
  path: string;
  summary: string;
  id?: string;
}
const { method, path, summary, id } = Astro.props;
const methodCls = `method-${method.toLowerCase()}`;
---

<section class="endpoint" id={id}>
  <div class="endpoint-head">
    <span class={`endpoint-method ${methodCls}`}>{method}</span>
    <code class="endpoint-path">{path}</code>
  </div>
  <p class="endpoint-summary">{summary}</p>
  <div class="endpoint-body">
    <slot />
  </div>
</section>

<style>
  .endpoint {
    margin: 32px 0;
    padding: 22px;
    border: 1px solid color-mix(in srgb, var(--on-surface) 9%, transparent);
    border-radius: var(--radius-l);
    background: color-mix(in srgb, var(--surface-bright) 88%, transparent);
    scroll-margin-top: calc(var(--header-h) + 20px);
  }

  .endpoint-head {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .endpoint-method {
    padding: 3px 10px;
    border-radius: var(--radius-s);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .method-get { background: var(--success-container); color: var(--on-success-container); }
  .method-post { background: var(--primary-container); color: var(--on-primary-container); }
  .method-put { background: var(--warning-container); color: var(--on-warning-container); }
  .method-delete { background: var(--error-container); color: var(--on-error-container); }

  .endpoint-path {
    font-size: 1rem;
    color: var(--on-surface);
    word-break: break-all;
  }

  .endpoint-summary {
    margin: 10px 0 0;
    color: var(--on-surface-variant);
    font-size: 0.94rem;
  }

  .endpoint-body {
    margin-top: 16px;
    font-size: 0.92rem;
  }
  .endpoint-body :global(h4) {
    margin: 20px 0 8px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--on-surface-dim);
    letter-spacing: 0.08em;
  }
  .endpoint-body :global(table) {
    width: 100%;
    margin: 10px 0;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  .endpoint-body :global(th),
  .endpoint-body :global(td) {
    padding: 8px 12px;
    border: 1px solid color-mix(in srgb, var(--on-surface) 10%, transparent);
    text-align: left;
  }
  .endpoint-body :global(th) {
    background: color-mix(in srgb, var(--on-surface) 5%, transparent);
    color: var(--on-surface);
  }
  .endpoint-body :global(td) { color: var(--on-surface-variant); }
  .endpoint-body :global(td code) {
    padding: 1px 6px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--on-surface) 7%, transparent);
    color: var(--primary);
    font-size: 0.85em;
    white-space: nowrap;
  }
</style>
