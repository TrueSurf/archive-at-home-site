---
/**
 * 页面背景层：二次元图/视频 + 遮罩系统。
 *
 * 素材放在 public/images/ 下，命名约定：
 *   bg-{name}.webp / .jpg / .png  静态背景
 *   bg-{name}.webm                动态背景（可选，存在时叠加播放）
 * 构建时检测文件是否存在，缺图自动回退到 CSS 渐变场景，无需改代码。
 * 视频层在 prefers-reduced-motion 或省流模式下不加载，仅显示静态图。
 */
import { existsSync } from 'node:fs';
import path from 'node:path';

interface Props {
  /** 背景名，对应 public/images/bg-{name}.* */
  name: string;
  /** object-position，控制画面焦点，如 'center 30%' */
  position?: string;
  /** 白色遮罩强度 0~1，画面偏暗/偏乱时调大 */
  dim?: number;
}

const { name, position = 'center 25%', dim = 0 } = Astro.props;

const dir = path.join(process.cwd(), 'public', 'images');
const image = ['webp', 'jpg', 'png']
  .map((ext) => `bg-${name}.${ext}`)
  .find((f) => existsSync(path.join(dir, f)));
const video = existsSync(path.join(dir, `bg-${name}.webm`)) ? `bg-${name}.webm` : null;
---

<div
  class="backdrop"
  style={`--bg-position:${position}; --bg-dim:${dim};`}
  aria-hidden="true"
>
  {image && <img src={`/images/${image}`} alt="" loading="eager" decoding="async" />}
  {
    video && (
      <video data-bg-video muted loop playsinline preload="auto" poster={image ? `/images/${image}` : undefined}>
        <source src={`/images/${video}`} type="video/webm" />
      </video>
    )
  }
</div>

<script>
  // 尊重减弱动态与省流模式：不满足条件时移除视频层，只保留静态图
  const v = document.querySelector<HTMLVideoElement>('[data-bg-video]');
  if (v) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as { connection?: { saveData?: boolean } }).connection?.saveData;
    if (reduce || saveData) {
      v.remove();
    } else {
      v.muted = true; // 部分浏览器只认属性不认 attribute
      v.addEventListener('playing', () => v.classList.add('ready'), { once: true });
      // 直接请求播放，不等 canplay：preload="auto" 可能被降级为仅 metadata，
      // 首次访问（无缓存）时 canplay 不触发，视频会永远停在 poster
      v.play().catch(() => {
        // 极端情况下被自动播放策略拒绝：等首次交互再试
        addEventListener('pointerdown', () => v.play().catch(() => {}), { once: true });
      });
    }
  }
</script>

<style>
  .backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    /* 渐变遮罩各档不透明度 */
    --veil-top: 0;
    --veil-mid1: 0;
    --veil-mid2: 0;
    --veil-bottom: 0.33;
  }

  /* 无图兜底：冷白底上浮两团淡淡的天蓝与薄荷 */
  .backdrop {
    background:
      radial-gradient(90% 70% at 15% 0%, rgba(29, 143, 208, 0.10), transparent 60%),
      radial-gradient(80% 60% at 90% 100%, rgba(53, 163, 134, 0.08), transparent 65%),
      linear-gradient(180deg, #f7fafb 0%, #f5f8f9 100%);
  }

  .backdrop img,
  .backdrop video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--bg-position);
  }

  .backdrop video {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .backdrop video.ready {
    opacity: 1;
  }

  /* 遮罩第一层：整体白色薄纱，保证文字对比度，强度可调 */
  .backdrop::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(246, 249, 250, var(--bg-dim));
  }

  /* 遮罩第二层：上下向页面底色过渡，图从画面中部透出 */
  .backdrop::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(246, 249, 250, var(--veil-top)) 0%,
      rgba(246, 249, 250, var(--veil-mid1)) 22%,
      rgba(246, 249, 250, var(--veil-mid2)) 55%,
      rgba(246, 249, 250, var(--veil-bottom)) 100%
    );
  }
</style>
