---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面不存在">
  <section class="container" style="padding:120px 20px; text-align:center;">
    <h1 style="font-size:2.2rem;">404</h1>
    <p style="color:var(--on-surface-variant); margin:16px 0 32px;">
      页面不存在或已被移动。
    </p>
    <div class="hero-actions" style="justify-content:center; display:flex; gap:12px;">
      <a class="btn btn-primary" href="/">回到首页</a>
      <a class="btn btn-ghost" href="/use">去解析归档</a>
    </div>
  </section>
</BaseLayout>
