---
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowDiagram from '../components/FlowDiagram.astro';
import { links, site } from '../data/site';
---

<BaseLayout bg="home" bgPosition="center 35%">
  <!-- Hero -->
  <section class="hero container">
    <span class="hero-kicker">E-Hentai 归档 · 公益解析网络</span>
    <h1>{site.name}</h1>
    <p class="hero-slogan">{site.slogan}</p>
    <p class="hero-desc">
      提交画廊链接，中控服务器将任务调度到志愿者节点，节点用自己的账号配额完成解析，返回归档下载链接。
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/use">立即使用</a>
      <a class="btn btn-ghost" href="/node">部署节点</a>
    </div>
  </section>

  <!-- 内容区（阅读底板） -->
  <div class="container page-shell">
  <!-- 工作原理 -->
  <section class="section" id="how">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>工作原理</h2>
    </div>
    <p class="section-desc">
      中控服务器负责任务调度、缓存与限流；解析任务由志愿者部署的节点执行，消耗节点自己的账号配额。
    </p>
    <FlowDiagram />
    <p class="section-desc">
      解析结果按用户缓存 7 天，期间重复请求直接命中缓存，不再消耗配额；新解析返回本次实际消耗的 GP。
    </p>
  </section>

  <!-- 特性 -->
  <section class="section">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>系统特性</h2>
    </div>
    <div class="card-grid">
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path><circle cx="10" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </span>
        <h3>志愿者节点网络</h3>
        <p>解析消耗节点自己的 E-Hentai 账号配额。网络的整体能力取决于在线节点的数量与配额。</p>
      </div>
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18"></path><path d="M8 4v5"></path></svg>
        </span>
        <h3>缓存与合并</h3>
        <p>每个用户独立的 7 天缓存；同一画廊的并发请求自动合并为一次解析。</p>
      </div>
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
        </span>
        <h3>GP 成本追踪</h3>
        <p>每次新解析返回实际 GP 消耗并写入任务日志，节点侧可查询统计。</p>
      </div>
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 3"></path></svg>
        </span>
        <h3>令牌桶限流</h3>
        <p>令牌以 1 GP/秒自动补充，容量上限约 7 天积累量；不足时稍后重试即可。</p>
      </div>
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2 3 10.5l7 2.5 2.5 7L21 2Z"></path><path d="M10 13 21 2"></path></svg>
        </span>
        <h3>Telegram 登录</h3>
        <p>Telegram 授权即自动注册，登录后分配 API Key，无需邮箱密码。</p>
      </div>
      <div class="card">
        <span class="card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </span>
        <h3>开放 API</h3>
        <p>REST API 开放，CORS 不限来源，凭 API Key 即可接入自有客户端。</p>
      </div>
    </div>
  </section>

  <!-- 三步上手 -->
  <section class="section">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>使用流程</h2>
    </div>
    <ol class="steps">
      <li>
        <div>
          <h3>获取 API Key</h3>
          <p>在<a href="/use">使用页</a>进行 Telegram 登录（首次登录自动注册），或向 <a href={links.telegramBot} target="_blank" rel="noopener">@ArchiveAtHome_bot</a> 领取。</p>
        </div>
      </li>
      <li>
        <div>
          <h3>选择客户端</h3>
          <p>网页版直接使用，或安装油猴脚本、使用 TG Bot、在 JHenTai 中配置归档机器人。</p>
        </div>
      </li>
      <li>
        <div>
          <h3>解析</h3>
          <p>粘贴画廊链接，返回归档下载链接。7 天内重复解析同一画廊命中缓存，不消耗 GP。</p>
        </div>
      </li>
    </ol>
  </section>

  <!-- 志愿者 CTA -->
  <section class="section">
    <div class="panel">
      <div class="panel-body" style="display:flex; flex-wrap:wrap; gap:20px; align-items:center; justify-content:space-between;">
        <div style="max-width:56ch;">
          <h2 style="font-size:1.3rem;">部署一个节点</h2>
          <p style="margin:10px 0 0; color:var(--on-surface-variant); font-size:0.94rem;">
            一台长期在线的设备和一个 E-Hentai 账号即可。节点自带 Dashboard 与本地解析日志。
          </p>
        </div>
        <a class="btn btn-primary" href="/node">查看部署指南</a>
      </div>
    </div>
  </section>
  </div>
</BaseLayout>
