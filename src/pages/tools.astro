---
import BaseLayout from '../layouts/BaseLayout.astro';
import { links } from '../data/site';

const sections = [
  {
    title: 'E-Hentai 账号工具',
    desc: '部署节点、排查 Cookie 问题时的趁手工具。',
    groups: [
      {
        name: '里站 Cookie 获取（主入口）',
        desc: '在线生成 ExHentai 可用的完整 Cookie（含 igneous），部署节点时需要。',
        url: 'https://excookie.mhdy.net',
      },
      {
        name: '里站 Cookie 获取（备用）',
        desc: '主入口不可用时的备用 igneous 生成器。',
        url: 'https://exhentai-igneous-generator.pages.dev/',
      },
    ],
  },
  {
    title: '里站账号渠道',
    desc: '没有 ExHentai 账号、想部署节点或自用时的获取渠道。交易类渠道请务必自行甄别。',
    warn: true,
    groups: [
      {
        name: '里站账号购买（真人对接）',
        desc: 'Telegram 联系，人工对接的账号渠道。',
        url: 'https://t.me/momo_pm',
      },
      {
        name: '里站账号购买（自助下单）',
        desc: '自动化网页商店「垃圾小店」，自助下单发货。',
        url: 'https://shop.mhdy.net/',
      },
    ],
  },
  {
    title: '本站生态',
    desc: 'Archive at Home 相关的仓库与社区入口。',
    groups: [
      { name: '主仓库（Server / Node）', desc: '中控服务器与节点程序源码、Releases 下载。', url: links.repoMain },
      { name: '油猴脚本仓库', desc: 'A@H 下载助手源码与问题反馈。', url: links.repoUserscript },
      { name: 'TG Bot 示例仓库', desc: '基于本平台 API 的 Telegram Bot 实现参考。', url: links.repoBot },
      { name: 'JHenTai 阅读器', desc: '内置本平台归档机器人支持的第三方阅读器。', url: links.jhentai },
      { name: 'Telegram 频道', desc: '平台公告、节点状态与志愿者交流。', url: links.telegramChannel },
    ],
  },
];
---

<BaseLayout title="工具与资源" bg="tools" bgPosition="center 40%">
  <div class="container page-shell">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>工具与资源</h2>
    </div>
    <p class="section-desc">E-Hentai 相关工具与常用入口。</p>

    <div class="callout callout-warn">
      <span class="callout-icon">⚠</span>
      <p>以下第三方链接均不由本平台运营，内容、安全性与交易风险请自行判断。涉及账号买卖时尤其注意甄别。</p>
    </div>

    {
      sections.map((sec) => (
        <section class="section" style="margin-top:48px;">
          <div class="section-title">
            <span class="section-mark" />
            <h2 style="font-size:1.25rem;">{sec.title}</h2>
          </div>
          <p class="section-desc">{sec.desc}</p>
          <div class="card-grid">
            {sec.groups.map((tool) => (
              <a class="card tool-item" href={tool.url} target="_blank" rel="noopener">
                <div>
                  <h3 style="font-size:1.05rem;">{tool.name}</h3>
                  <p>{tool.desc}</p>
                  <div class="card-meta">{new URL(tool.url).hostname} ↗</div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
