---
import BaseLayout from '../layouts/BaseLayout.astro';
import { links } from '../data/site';

const apps = [
  {
    name: 'Telegram Bot',
    badge: { text: '官方', cls: 'badge-amber' },
    desc: '把画廊链接直接发给 Bot 即可解析。支持群组使用，支持 inline 模式预览画廊。',
    points: ['私聊或群组中发送 e-hentai / exhentai 画廊链接', '任意聊天输入 @ArchiveAtHome_bot + 链接，可预览画廊信息', '首次使用按提示登录绑定，/myinfo 可随时查看自己的 API Key'],
    action: { href: links.telegramBot, text: '打开 @ArchiveAtHome_bot' },
  },
  {
    name: '油猴脚本 · A@H 下载助手',
    badge: { text: '官方', cls: 'badge-amber' },
    desc: '在 E-Hentai 画廊页面注入悬浮面板：一键解析当前画廊、显示余额、解析成功可直接下载。',
    points: ['需要 Tampermonkey / Violentmonkey 等脚本管理器', '面板内可直接完成 Telegram 登录', '上方网页版工具功能与本脚本一致'],
    action: { href: links.userscriptInstall, text: '安装脚本' },
    repo: links.repoUserscript,
  },
  {
    name: 'JHenTai（第三方阅读器）',
    badge: { text: '第三方', cls: 'badge-sky' },
    desc: 'Android / iOS / 桌面端 E-Hentai 阅读器，内置归档机器人支持，配置后可在 App 内直接解析下载归档。',
    points: [
      '设置 → 下载设置 → 归档机器人设置',
      '接口协议选 ArchiveAtHome，API 地址填 https://api.archive-at-home.org/jhentai',
      '填入你的 API Key，保存后会自动校验并显示 GP 余额',
      '在画廊页点归档按钮，选择 🤖 图标即可通过本平台下载',
    ],
    action: { href: links.jhentaiDownload, text: '下载 JHenTai' },
    repo: links.jhentai,
  },
  {
    name: '你自己的应用',
    badge: { text: '开发者', cls: 'badge-green' },
    desc: 'REST API 开放，CORS 不限来源，凭 API Key 即可接入自有脚本、Bot 或阅读器插件。',
    points: ['接口见 API 文档', '建议通过 X-Client 头标记应用来源'],
    action: { href: '/api', text: '查看 API 文档' },
  },
];
---

<BaseLayout title="使用方式" bg="use" bgPosition="center 25%">
  <div class="container page-shell">
  <section style="padding-top:0;">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>网页版</h2>
    </div>
    <p class="section-desc">
      Telegram 登录（首次登录自动注册），粘贴画廊链接即可解析。API Key 仅保存在本地浏览器。
    </p>

    <div class="panel" id="parse-tool">
      <!-- 未登录视图 -->
      <div id="pt-view-login" hidden>
        <div class="panel-head">登录以继续</div>
        <div class="panel-body">
          <p style="margin-top:0; color:var(--on-surface-variant); font-size:0.92rem;">
            使用 Telegram 账号登录，首次授权自动注册并分配 API Key。
          </p>
          <div class="btn-row" style="margin-top:16px;">
            <a class="btn btn-primary" id="pt-tg-login" href="#" rel="noopener">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.9 4.6c.2-1-.7-1.6-1.6-1.2L2.7 10c-1 .4-1 1.7.1 2l4.4 1.4 1.7 5.3c.3.9 1.4 1.1 2 .4l2.4-2.5 4.4 3.2c.8.6 2 .2 2.2-.8l2-14.4ZM7.9 12.6l10.6-6.6c.2-.1.4.2.2.3l-8.7 7.9-.3 3-1.8-4.6Z"></path></svg>
              使用 Telegram 登录
            </a>
          </div>
          <div class="field" style="margin-top:22px;">
            <label for="pt-key-input">已经有 Key 了？直接粘贴（sk- 开头）</label>
            <input id="pt-key-input" type="password" placeholder="sk-…" autocomplete="off" spellcheck="false" />
          </div>
          <div class="btn-row">
            <button class="btn btn-ghost btn-sm" id="pt-save-key" type="button">保存并验证</button>
          </div>
          <div class="msg" id="pt-login-msg"></div>
        </div>
      </div>

      <!-- 已登录视图 -->
      <div id="pt-view-main" hidden>
        <div class="panel-head">
          解析归档链接
          <span style="margin-left:auto; display:flex; gap:8px;">
            <button class="btn btn-ghost btn-sm" id="pt-refresh" type="button">刷新余额</button>
            <button class="btn btn-ghost btn-sm" id="pt-logout" type="button">退出登录</button>
          </span>
        </div>
        <div class="panel-body">
          <dl class="kv" id="pt-profile"></dl>

          <div class="field" style="margin-top:18px;">
            <label for="pt-gallery">画廊链接（e-hentai.org / exhentai.org），或「画廊ID 密钥」</label>
            <input id="pt-gallery" type="text" placeholder="https://e-hentai.org/g/3858751/d3de60e849/" autocomplete="off" spellcheck="false" />
          </div>

          <label class="checkline">
            <input id="pt-autodl" type="checkbox" />
            解析成功后直接开始下载
          </label>

          <div class="btn-row">
            <button class="btn btn-primary" id="pt-parse" type="button">解析下载链接</button>
            <button class="btn btn-ghost" id="pt-force" type="button" title="忽略 7 天缓存，重新消耗 GP 解析">强制重试</button>
          </div>

          <div class="msg" id="pt-parse-msg"></div>
          <div id="pt-result"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 应用列表 -->
  <section class="section">
    <div class="section-title">
      <span class="section-mark"></span>
      <h2>更多使用方式</h2>
    </div>
    <p class="section-desc">
      同一 API Key 在所有客户端通用。
    </p>
    <div class="card-grid">
      {
        apps.map((app) => (
          <div class="card app-card">
            <div class="app-card-head">
              <h3>{app.name}</h3>
              <span class={`badge ${app.badge.cls}`}>{app.badge.text}</span>
            </div>
            <p>{app.desc}</p>
            <ul class="app-points">
              {app.points.map((pt) => (
                <li>{pt}</li>
              ))}
            </ul>
            <div class="btn-row">
              <a class="btn btn-ghost btn-sm" href={app.action.href} target={app.action.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
                {app.action.text} →
              </a>
              {app.repo && (
                <a class="btn btn-ghost btn-sm" href={app.repo} target="_blank" rel="noopener">
                  源码
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>
  </div>
</BaseLayout>

<script>
  import '../scripts/parse-tool';
</script>

<style>
  .app-card .app-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }
  .app-card .app-card-head h3 { margin: 0; }
  .app-points {
    margin: 12px 0 0;
    padding-left: 1.3em;
    color: var(--on-surface-dim);
    font-size: 0.86rem;
  }
  .app-points li { margin: 5px 0; }
  .app-points li::marker { color: var(--primary-deep); }

  #pt-result {
    margin-top: 14px;
  }
  #pt-result:empty { display: none; }
  #pt-result .pt-result-head {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }
  #pt-result .pt-result-url {
    display: block;
    padding: 10px 12px;
    border: 1px solid var(--code-border);
    border-radius: var(--radius-m);
    background: var(--code-bg);
    color: var(--code-text);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    word-break: break-all;
  }
</style>
